// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Service {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  category    String    // "hair-braiding" | "african-cuisine" | "other"
  description String
  longDesc    String?
  price       Float
  duration    Int       // in minutes
  imageUrl    String
  featured    Boolean   @default(false)
  active      Boolean   @default(true)
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id            String    @id @default(cuid())
  customerName  String
  email         String
  phone         String
  service       Service   @relation(fields: [serviceId], references: [id])
  serviceId     String
  date          DateTime
  timeSlot      String    // e.g. "10:00 AM"
  notes         String?
  status        String    @default("pending") // pending | confirmed | cancelled | completed
  paymentStatus String    @default("unpaid")  // unpaid | paid (Stripe provision)
  paymentRef    String?   // Stripe payment intent id
  emailSent     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Review {
  id           String   @id @default(cuid())
  customerName String
  email        String?
  serviceType  String   // "hair-braiding" | "african-cuisine" | "general"
  rating       Int      // 1-5
  comment      String
  photoUrl     String?
  approved     Boolean  @default(false)
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // hashed
  name      String
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
